<div id="filters-wrap">
  <div id="filters">
    <a href="/listings?category=Trending" class="filter" onclick="setActiveFilter(event,this)">
      <i class="fa-solid fa-fire"></i>
      <span>Trending</span>
    </a>
    <a href="/listings?category=Rooms" class="filter" onclick="setActiveFilter(event,this)">
      <i class="fa-solid fa-bed"></i>
      <span>Rooms</span>
    </a>
    <a href="/listings?category=Iconic Cities" class="filter" onclick="setActiveFilter(event,this)">
      <i class="fa-solid fa-mountain-city"></i>
      <span>Iconic Cities</span>
    </a>
    <a href="/listings?category=Mountains" class="filter" onclick="setActiveFilter(event,this)">
      <i class="fa-solid fa-mountain"></i>
      <span>Mountains</span>
    </a>
    <a href="/listings?category=Castles" class="filter" onclick="setActiveFilter(event,this)">
      <i class="fa-brands fa-fort-awesome"></i>
      <span>Castles</span>
    </a>
    <a href="/listings?category=Amazing pools" class="filter" onclick="setActiveFilter(event,this)">
      <i class="fa-solid fa-person-swimming"></i>
      <span>Amazing Pools</span>
    </a>
    <a href="/listings?category=Camping" class="filter" onclick="setActiveFilter(event,this)">
      <i class="fa-solid fa-campground"></i>
      <span>Camping</span>
    </a>
    <a href="/listings?category=Farms" class="filter" onclick="setActiveFilter(event,this)">
      <i class="fa-solid fa-cow"></i>
      <span>Farms</span>
    </a>
    <a href="/listings?category=Arctic" class="filter" onclick="setActiveFilter(event,this)">
      <i class="fa-regular fa-snowflake"></i>
      <span>Arctic</span>
    </a>
    <a href="/listings" class="filter" onclick="setActiveFilter(event,this)">
      <i class="fa-solid fa-border-all"></i>
      <span>All</span>
    </a>
  </div>

  <div class="tax-toggle">
    <div class="form-check-reverse form-switch mb-0">
      <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
      <label class="form-check-label" for="switchCheckDefault" style="font-size:12px; font-weight:500;">
        Tax
      </label>
    </div>
  </div>
</div>


<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
    <% for(let listing of allListings){ %>
        <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="card col listing-card">
            <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 20rem;">
            <div class="card-img-overlay"></div>
                <div class="card-body">
                    <p class="card-text"><b><%= listing.title %></b></p>
                    &#8377;<%= listing.price.toLocaleString("en-IN") %>/night
                    <i class="tax-info">+18% GST</i>
                </div>
            </div>
        </a>
    <% } %>
</div>
    <script>
    // Highlight active filter based on current URL param
    const params = new URLSearchParams(window.location.search);
    const activeCategory = params.get('category');
    document.querySelectorAll('.filter').forEach(f => {
      const href = f.getAttribute('href');
      if (activeCategory && href.includes(activeCategory)) f.classList.add('active');
      else if (!activeCategory && href === '/listings') f.classList.add('active');
    });

    // Tax toggle
    document.getElementById('switchCheckDefault').addEventListener('change', function () {
      document.querySelectorAll('.tax-info').forEach(el => {
        el.style.display = this.checked ? 'inline' : 'none';
      });
    });
  </script>
</body>