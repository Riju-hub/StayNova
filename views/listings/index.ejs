<% layout("layouts/boilerplate") %>
<body><br>

<style>
  /* Filter bar wrapper */
  #filters-wrap {
    display: flex;
    align-items: center;
    border-bottom: 1px solid #f0f0f0;
    background: #fff;
    padding: 0 0.5rem;
    position: sticky;
    top: 5rem; /* match your navbar height */
    z-index: 100;
  }

  /* Scrollable filter strip */
  #filters {
    display: flex;
    align-items: center;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
    flex: 1;
    padding: 10px 0;
  }
  #filters::-webkit-scrollbar { display: none; }

  /* Each filter pill */
  .filter {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    cursor: pointer;
    text-decoration: none;
    color: #717171;
    border-bottom: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
    white-space: nowrap;
    flex-shrink: 0;
    font-size: 11px;
    font-weight: 500;
  }
  .filter i { font-size: 20px; transition: transform 0.15s; }
  .filter:hover { color: #222; border-bottom-color: #b0b0b0; }
  .filter:hover i { transform: scale(1.1); }
  .filter.active { color: #222; border-bottom-color: #222; font-weight: 600; }
  .filter.active i { transform: scale(1.1); }

  /* Tax toggle */
  .tax-toggle {
    flex-shrink: 0;
    margin-left: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 14px;
    border: 1px solid #ddd;
    border-radius: 8px;
    cursor: pointer;
    white-space: nowrap;
    transition: border-color 0.15s;
    background: #fff;
  }
  .tax-toggle:hover { border-color: #222; }

  .tax-info { display: none; }
</style>


